# Copy to .env and fill in. Vite exposes only VITE_-prefixed vars to the client.

# Supabase project API URL + publishable/anon key (Dashboard → Settings → API).
# The publishable key is safe to ship in the client bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API base. Empty = same-origin (web dev uses the Vite proxy to :3001).
# Electron (file://) and the deployed web build MUST set this to the backend URL,
# e.g. https://husai-api.onrender.com
VITE_API_BASE_URL=
