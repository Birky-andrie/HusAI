// Database: PostgreSQL (Supabase) for both local dev and production.
//
// Portability legacy: this schema was written provider-agnostic (no enums, no
// provider-specific types; JSON stored as String; role-like fields are strings
// validated in application code). Those constraints are kept so the schema stays
// simple, but the target is now Postgres only. The connection URL comes from
// DATABASE_URL via prisma.config.ts (migrations) and the pg driver adapter (runtime).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Identity is owned by Supabase Auth (auth.users). This row mirrors the Supabase
// user so the app's data can foreign-key to it: `id` is the Supabase auth uid,
// provisioned just-in-time on the user's first authenticated request. No
// password/token/oauth columns — Supabase manages credentials and sessions.
model User {
  id              String   @id // = Supabase auth uid (uuid)
  email           String   @unique
  displayName     String?
  emailVerifiedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  settings        UserSettings?
  meetings        Meeting[]
  reviews         Review[]
  practiceSessions PracticeSession[]
  progressMetrics ProgressMetric[]
}

model Meeting {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt       DateTime
  durationSeconds Int
  platform        String // 'web' | 'desktop'
  transcript      String // "VA:"/"Client:"-labeled lines
  createdAt       DateTime @default(now())
  review          Review?
}

model Review {
  id            String   @id @default(cuid())
  meetingId     String   @unique
  meeting       Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  overallScore  Int
  insightsJson  String // JSON as String: Prisma has no Json type on SQLite
  exercisesJson String
  scoresJson    String
  metricsJson   String
  createdAt     DateTime @default(now())
  practiceSessions PracticeSession[]
}

model PracticeSession {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewId         String?
  review           Review?   @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  title            String
  scenario         String
  targetSkillsJson String
  difficulty       Int // 1-5
  status           String    @default("active") // 'active' | 'completed'
  summaryJson      String?
  createdAt        DateTime  @default(now())
  endedAt          DateTime?
  turns            PracticeTurn[]
}

model PracticeTurn {
  id           String          @id @default(cuid())
  sessionId    String
  session      PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         String // 'client' | 'va'
  text         String
  feedbackJson String?
  createdAt    DateTime        @default(now())
}

model ProgressMetric {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source    String // 'call' | 'practice'
  refId     String // meetingId or practiceSessionId
  dimension String // 'overall' | 'confidence' | 'clarity' | ...
  value     Float
  createdAt DateTime @default(now())

  @@index([userId, dimension, createdAt])
}

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Days conversation transcripts are kept before the cleanup job deletes them.
  // Reviews and progress metrics are never auto-deleted.
  transcriptRetentionDays Int @default(30)

  // Seconds of post-client-turn silence before a Lifeline fires (Phase 2).
  lifelinePauseSeconds Float @default(1.5)

  // JSON as String (SQLite): { emailReviewReady?: boolean, emailPracticeReminders?: boolean }
  notificationPrefsJson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
