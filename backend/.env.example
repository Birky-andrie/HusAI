# Copy to .env and fill in. NEVER commit .env.
# Free Groq key (no card): https://console.groq.com/keys
GROQ_API_KEY=
# Free Gemini key (no card): https://aistudio.google.com/apikey
GEMINI_API_KEY=
PORT=3001

# Allowed frontend origin for CORS in production (e.g. https://husai.vercel.app).
# Leave empty to allow all origins (fine for local dev / alpha).
FRONTEND_ORIGIN=

# Daily caps enforced BEFORE calling providers — ~10% headroom under real
# free-tier limits, shared across ALL alpha users (limits are per org, not per user).
# llama-3.1-8b-instant free tier: 14,400 req/day
GROQ_DAILY_CAP=12960
# whisper-large-v3-turbo free tier: 2,000 req/day (desktop transcription is the expensive path)
GROQ_WHISPER_DAILY_CAP=1800
# gemini-3.5-flash free tier: ~250 req/day (Google no longer publishes this; conservative)
GEMINI_DAILY_CAP=225

# PostgreSQL (Supabase) — used for BOTH local dev and production (dev/prod parity).
# Create a free project at https://supabase.com → New project.
# Then: Dashboard → Connect (top bar) → "Session pooler" → copy the URI. Shape:
#   postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# The Session pooler is IPv4 (works on free hosts like Render) and supports
# migrations directly, so no separate DIRECT_URL is needed at this scale.
DATABASE_URL=

# Supabase Auth — the backend verifies user access tokens against this project's
# public JWKS (no shared secret needed). Project API URL: https://<ref>.supabase.co
SUPABASE_URL=
# Optional. ONLY to hard-delete a user's Supabase auth identity on account
# deletion. Highly privileged — keep secret. Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Secret for signing JWTs. Generate your own: openssl rand -base64 48
JWT_SECRET=

# Where auth emails (verify/reset links) point, and where OAuth returns users.
FRONTEND_URL=http://localhost:5173
# Public URL of this backend (OAuth providers redirect here). Set in production.
API_BASE_URL=http://localhost:3001

# Email sending. Leave empty for dev: verification/reset links print to this
# terminal instead. Free key (100 emails/day, no card): https://resend.com
RESEND_API_KEY=
EMAIL_FROM=HusAI <onboarding@resend.dev>

# Google Sign-In (optional — button appears when both are set).
# Create at https://console.cloud.google.com/apis/credentials → OAuth client ID
# (Web application). Authorized redirect URI: {API_BASE_URL}/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Sign-In (optional — button appears when both are set).
# Create at https://portal.azure.com → App registrations → New (any-org + personal accounts).
# Redirect URI (Web): {API_BASE_URL}/api/auth/oauth/microsoft/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=
